<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.snowxk.lease.web.admin.mapper.FeeKeyMapper">

    <resultMap id="FeeKeyVoMap" type="com.snowxk.lease.web.admin.vo.fee.FeeKeyVo" autoMapping="true">
        <id property="id" column="id"/>
        <collection property="feeValueList" ofType="com.snowxk.lease.model.entity.FeeValue" autoMapping="true">
            <id property="id" column="fee_value_id"/>
            <result property="name" column="fee_value_name"/>
        </collection>
    </resultMap>
    <select id="feeInfoList" resultMap="FeeKeyVoMap">
        select fk.id,
               fk.name,
               fv.id   as fee_value_id,
               fv.name as fee_value_name,
               fv.unit,
               fv.fee_key_id
        from fee_key fk
                 left join fee_value fv
                           on fk.id = fv.fee_key_id and fv.is_deleted = 0
        where fk.is_deleted = 0
    </select>
</mapper>
